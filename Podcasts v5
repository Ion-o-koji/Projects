<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Podflow</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    :root {
      --bg: #0A0A11;
      --bg-2: #0F0F18;
      --surface: #15151F;
      --surface-2: #1B1B28;
      --surface-3: #232333;
      --accent: #E8734A;
      --accent-hover: #F08A66;
      --accent-dim: rgba(232,115,74,0.12);
      --accent-glow: rgba(232,115,74,0.25);
      --text: #EAEAF0;
      --text-2: #9090A8;
      --text-3: #5C5C72;
      --border: #262638;
      --success: #4ADE80;
      --error: #F87171;
      --radius: 14px;
      --radius-sm: 10px;
      --radius-lg: 20px;
      --tab-h: 60px;
      --player-h: 62px;
      --safe-b: env(safe-area-inset-bottom, 0px);
      --safe-t: env(safe-area-inset-top, 0px);
      --font: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    html, body {
      height: 100%; overflow: hidden;
      background: var(--bg); color: var(--text);
      font-family: var(--font);
      -webkit-font-smoothing: antialiased;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }

    :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; color: inherit; }
    input { font-family: inherit; border: none; background: none; color: inherit; outline: none; }
    img { display: block; }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--surface-3); border-radius: 2px; }

    /* ========== LAYOUT ========== */
    #app {
      display: flex; flex-direction: column;
      height: 100dvh; position: relative; overflow: hidden;
    }

    #views {
      flex: 1; position: relative; overflow: hidden;
    }

    .view {
      position: absolute; inset: 0;
      display: none; flex-direction: column;
      overflow: hidden;
    }
    .view.active { display: flex; }

    .view-header {
      flex-shrink: 0; padding: 16px 20px 0;
      padding-top: calc(16px + var(--safe-t));
    }
    .view-header h1 {
      font-size: 28px; font-weight: 800; letter-spacing: -0.5px;
    }

    .view-content {
      flex: 1; overflow-y: auto; overflow-x: hidden;
      padding: 16px 20px;
      padding-bottom: calc(var(--tab-h) + var(--safe-b) + 24px);
      -webkit-overflow-scrolling: touch;
    }
    .view-content.has-player {
      padding-bottom: calc(var(--tab-h) + var(--player-h) + var(--safe-b) + 24px);
    }

    /* ========== TAB BAR ========== */
    #tab-bar {
      flex-shrink: 0; display: flex; align-items: stretch;
      background: var(--bg-2); border-top: 1px solid var(--border);
      padding-bottom: var(--safe-b); position: relative; z-index: 100;
    }

    .tab-btn {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 3px;
      padding: 8px 0; color: var(--text-3);
      transition: color 0.2s; position: relative;
    }
    .tab-btn i { font-size: 18px; transition: transform 0.2s; }
    .tab-btn span { font-size: 10px; font-weight: 600; letter-spacing: 0.3px; }
    .tab-btn.active { color: var(--accent); }
    .tab-btn.active i { transform: scale(1.1); }
    .tab-btn::before {
      content: ''; position: absolute; top: 0; left: 50%;
      transform: translateX(-50%); width: 24px; height: 2px;
      border-radius: 0 0 2px 2px; background: var(--accent);
      opacity: 0; transition: opacity 0.2s;
    }
    .tab-btn.active::before { opacity: 1; }

    /* ========== MINI PLAYER ========== */
    #mini-player {
      flex-shrink: 0; height: 0; overflow: hidden;
      background: var(--surface); border-top: 1px solid var(--border);
      transition: height 0.3s cubic-bezier(0.4,0,0.2,1);
      position: relative; z-index: 90; cursor: pointer;
    }
    #mini-player.visible { height: var(--player-h); }

    .mini-progress {
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: var(--surface-3);
    }
    .mini-progress-fill {
      height: 100%; background: var(--accent); width: 0%;
      transition: width 0.3s linear;
    }
    .mini-inner {
      display: flex; align-items: center; gap: 12px;
      padding: 8px 16px; height: var(--player-h);
    }
    .mini-art {
      width: 42px; height: 42px; border-radius: 8px;
      object-fit: cover; background: var(--surface-3); flex-shrink: 0;
    }
    .mini-info { flex: 1; min-width: 0; }
    .mini-title {
      font-size: 13px; font-weight: 600; white-space: nowrap;
      overflow: hidden; text-overflow: ellipsis;
    }
    .mini-sub {
      font-size: 11px; color: var(--text-3); white-space: nowrap;
      overflow: hidden; text-overflow: ellipsis;
    }
    .mini-play {
      width: 38px; height: 38px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      background: var(--accent); color: #fff; font-size: 14px;
      flex-shrink: 0; transition: transform 0.15s, background 0.15s;
    }
    .mini-play:active { transform: scale(0.9); }

    /* ========== FULL PLAYER ========== */
    #full-player {
      position: fixed; inset: 0; z-index: 200;
      background: var(--bg); display: flex; flex-direction: column;
      transform: translateY(100%);
      transition: transform 0.4s cubic-bezier(0.32,0.72,0,1);
    }
    #full-player.open { transform: translateY(0); }

    .fp-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 20px; padding-top: calc(12px + var(--safe-t));
      flex-shrink: 0;
    }
    .fp-header button { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-size: 18px; color: var(--text-2); }
    .fp-header span { font-size: 12px; font-weight: 600; color: var(--text-3); text-transform: uppercase; letter-spacing: 1.5px; }

    .fp-body {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 0 32px 32px; gap: 28px;
    }

    .fp-artwork {
      width: min(70vw, 320px); aspect-ratio: 1; border-radius: var(--radius-lg);
      object-fit: cover; background: var(--surface-2);
      box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 80px var(--accent-glow);
    }

    .fp-info { text-align: center; width: 100%; }
    .fp-title {
      font-size: 20px; font-weight: 700; line-height: 1.3;
      display: -webkit-box; -webkit-line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    .fp-podcast { font-size: 14px; color: var(--accent); font-weight: 500; margin-top: 4px; }

    .fp-seek { width: 100%; }
    .fp-seek input[type="range"] {
      -webkit-appearance: none; appearance: none;
      width: 100%; height: 4px; border-radius: 2px;
      background: var(--surface-3); outline: none;
    }
    .fp-seek input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none; width: 16px; height: 16px;
      border-radius: 50%; background: var(--accent); cursor: pointer;
      box-shadow: 0 0 8px var(--accent-glow);
    }
    .fp-seek input[type="range"]::-moz-range-thumb {
      width: 16px; height: 16px; border: none;
      border-radius: 50%; background: var(--accent); cursor: pointer;
    }
    .fp-times {
      display: flex; justify-content: space-between;
      font-size: 12px; color: var(--text-3); margin-top: 6px;
      font-variant-numeric: tabular-nums;
    }

    .fp-controls {
      display: flex; align-items: center; gap: 28px;
    }
    .fp-ctrl {
      display: flex; align-items: center; justify-content: center;
      color: var(--text-2); font-size: 22px; transition: color 0.15s;
    }
    .fp-ctrl:active { color: var(--text); }
    .fp-ctrl.small { font-size: 18px; }
    .fp-play {
      width: 64px; height: 64px; border-radius: 50%;
      background: var(--accent); color: #fff; font-size: 24px;
      display: flex; align-items: center; justify-content: center;
      transition: transform 0.15s, background 0.15s;
      box-shadow: 0 4px 20px var(--accent-glow);
    }
    .fp-play:active { transform: scale(0.92); }
    .fp-speed {
      font-size: 13px; font-weight: 700; color: var(--accent);
      border: 1.5px solid var(--accent); border-radius: 6px;
      padding: 4px 8px; transition: background 0.15s;
    }
    .fp-speed:active { background: var(--accent-dim); }

    .fp-bottom-actions {
      display: flex; gap: 12px; padding: 0 32px;
      justify-content: center; flex-wrap: wrap;
    }
    .fp-action-btn {
      padding: 10px 18px; border-radius: var(--radius-sm);
      font-size: 13px; font-weight: 600; display: flex;
      align-items: center; gap: 8px;
      background: var(--accent); color: #fff;
      border: none;
      transition: transform 0.1s, background 0.15s;
      position: relative;
    }
    .fp-action-btn:active { transform: scale(0.95); }
    .fp-action-btn.downloading {
      background: var(--accent); color: #fff;
    }
    .fp-action-btn.downloading i { animation: spin 0.8s linear infinite; }
    .fp-action-btn.done {
      background: rgba(74,222,128,0.2); color: var(--success);
    }

    /* ========== SEARCH ========== */
    .search-bar {
      display: flex; align-items: center; gap: 10px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 0 14px; height: 46px;
      transition: border-color 0.2s;
    }
    .search-bar:focus-within { border-color: var(--accent); }
    .search-bar i { color: var(--text-3); font-size: 14px; flex-shrink: 0; }
    .search-bar input { flex: 1; font-size: 15px; height: 100%; }
    .search-bar input::placeholder { color: var(--text-3); }
    .search-clear {
      width: 24px; height: 24px; border-radius: 50%;
      display: none; align-items: center; justify-content: center;
      background: var(--surface-3); color: var(--text-2); font-size: 10px;
    }
    .search-clear.visible { display: flex; }

    /* ========== CARDS ========== */
    .pod-card {
      display: flex; align-items: center; gap: 14px;
      padding: 12px; border-radius: var(--radius);
      background: var(--surface); border: 1px solid var(--border);
      margin-bottom: 8px; transition: transform 0.15s, background 0.15s;
      cursor: pointer;
    }
    .pod-card:active { transform: scale(0.98); background: var(--surface-2); }
    .pod-card-art {
      width: 56px; height: 56px; border-radius: var(--radius-sm);
      object-fit: cover; background: var(--surface-3); flex-shrink: 0;
    }
    .pod-card-info { flex: 1; min-width: 0; }
    .pod-card-title {
      font-size: 15px; font-weight: 600; line-height: 1.3;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .pod-card-artist {
      font-size: 13px; color: var(--text-2); margin-top: 2px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .pod-card-chevron { color: var(--text-3); font-size: 12px; }

    .ep-item {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 0; border-bottom: 1px solid var(--border);
      position: relative;
    }
    .ep-item:last-child { border-bottom: none; }
    .ep-play-btn {
      width: 40px; height: 40px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      background: var(--accent-dim); color: var(--accent); font-size: 14px;
      flex-shrink: 0; transition: background 0.15s, transform 0.1s;
    }
    .ep-play-btn:active { transform: scale(0.9); background: var(--accent-glow); }
    .ep-info { flex: 1; min-width: 0; cursor: pointer; }
    .ep-title {
      font-size: 14px; font-weight: 500; line-height: 1.4;
      display: -webkit-box; -webkit-line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    .ep-meta {
      font-size: 12px; color: var(--text-3); margin-top: 3px;
      display: flex; gap: 8px; align-items: center;
    }
    .ep-dl-btn {
      width: 44px; height: 44px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 14px; flex-shrink: 0;
      transition: background 0.15s, transform 0.1s;
      background: var(--accent);
      font-weight: 600;
      position: relative;
    }
    .ep-dl-btn:active { transform: scale(0.95); }
    .ep-dl-btn.downloading { animation: spin 0.8s linear infinite; }
    .ep-dl-btn.done {
      background: rgba(74,222,128,0.2); color: var(--success);
    }
    .ep-dl-btn.failed { color: var(--error); background: rgba(248,113,113,0.1); }
    .ep-dl-badge {
      position: absolute; top: -4px; right: -4px;
      width: 16px; height: 16px; border-radius: 50%;
      background: var(--success); color: #fff;
      display: none; align-items: center; justify-content: center;
      font-size: 10px; font-weight: bold;
    }
    .ep-dl-badge.shown { display: flex; }

    /* ========== OVERLAY (PODCAST DETAIL) ========== */
    #podcast-detail {
      position: fixed; inset: 0; z-index: 150;
      background: var(--bg); display: flex; flex-direction: column;
      transform: translateX(100%);
      transition: transform 0.32s cubic-bezier(0.32,0.72,0,1);
    }
    #podcast-detail.open { transform: translateX(0); }

    .detail-header {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 16px; padding-top: calc(10px + var(--safe-t));
      border-bottom: 1px solid var(--border); flex-shrink: 0;
    }
    .detail-back {
      width: 38px; height: 38px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; color: var(--text-2);
    }
    .detail-back:active { background: var(--surface-2); }
    .detail-header-title {
      flex: 1; font-size: 16px; font-weight: 600;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .detail-follow-btn {
      padding: 7px 14px; border-radius: 20px; font-size: 13px; font-weight: 600;
      display: flex; align-items: center; gap: 6px;
      transition: background 0.2s, color 0.2s;
    }
    .detail-follow-btn.not-following {
      background: var(--accent); color: #fff;
    }
    .detail-follow-btn.following {
      background: var(--accent-dim); color: var(--accent);
    }

    .detail-hero {
      display: flex; align-items: center; gap: 16px;
      padding: 20px; flex-shrink: 0;
    }
    .detail-art {
      width: 96px; height: 96px; border-radius: var(--radius);
      object-fit: cover; background: var(--surface-3); flex-shrink: 0;
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    }
    .detail-hero-info { flex: 1; min-width: 0; }
    .detail-hero-title {
      font-size: 20px; font-weight: 700; line-height: 1.2;
      display: -webkit-box; -webkit-line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    .detail-hero-artist {
      font-size: 14px; color: var(--text-2); margin-top: 4px;
    }
    .detail-hero-count {
      font-size: 12px; color: var(--text-3); margin-top: 2px;
    }

    .detail-actions {
      display: flex; gap: 10px; padding: 0 20px 16px; flex-shrink: 0;
    }
    .action-btn {
      flex: 1; padding: 11px 0; border-radius: var(--radius-sm);
      font-size: 13px; font-weight: 600; display: flex;
      align-items: center; justify-content: center; gap: 8px;
      transition: transform 0.1s, opacity 0.15s;
    }
    .action-btn:active { transform: scale(0.97); }
    .action-btn.primary { background: var(--accent); color: #fff; }
    .action-btn.secondary { background: var(--surface-2); color: var(--text-2); border: 1px solid var(--border); }

    .detail-eps {
      flex: 1; overflow-y: auto; padding: 0 20px;
      padding-bottom: calc(var(--tab-h) + var(--safe-b) + 24px);
    }
    .detail-eps-title {
      font-size: 13px; font-weight: 700; color: var(--text-3);
      text-transform: uppercase; letter-spacing: 1px;
      margin-bottom: 4px;
    }

    /* ========== FOLLOWING FEED ========== */
    .feed-ep {
      display: flex; gap: 12px; padding: 14px 0;
      border-bottom: 1px solid var(--border);
    }
    .feed-ep:last-child { border-bottom: none; }
    .feed-ep-art {
      width: 48px; height: 48px; border-radius: 8px;
      object-fit: cover; background: var(--surface-3); flex-shrink: 0;
    }
    .feed-ep-info { flex: 1; min-width: 0; }
    .feed-ep-pod {
      font-size: 11px; font-weight: 600; color: var(--accent);
      text-transform: uppercase; letter-spacing: 0.5px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .feed-ep-title {
      font-size: 14px; font-weight: 500; line-height: 1.35; margin-top: 2px;
      display: -webkit-box; -webkit-line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    .feed-ep-meta {
      font-size: 12px; color: var(--text-3); margin-top: 4px;
      display: flex; gap: 8px; align-items: center;
    }
    .feed-ep-actions {
      display: flex; align-items: center; gap: 4px; flex-shrink: 0;
    }

    /* ========== SETTINGS ========== */
    .settings-section {
      margin-bottom: 28px;
    }
    .settings-label {
      font-size: 11px; font-weight: 700; color: var(--text-3);
      text-transform: uppercase; letter-spacing: 1.2px;
      margin-bottom: 8px; padding-left: 4px;
    }
    .settings-group {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); overflow: hidden;
    }
    .settings-item {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 16px; gap: 12px;
    }
    .settings-item:not(:last-child) { border-bottom: 1px solid var(--border); }
    .settings-item-label { font-size: 14px; font-weight: 500; }
    .settings-item-value { font-size: 14px; color: var(--text-2); display: flex; align-items: center; gap: 6px; }
    .settings-item-btn {
      font-size: 14px; color: var(--error); font-weight: 500;
      padding: 14px 16px; width: 100%; text-align: left;
    }

    .speed-options {
      display: flex; gap: 6px; flex-wrap: wrap;
    }
    .speed-opt {
      padding: 6px 12px; border-radius: 8px; font-size: 13px; font-weight: 600;
      background: var(--surface-2); color: var(--text-2);
      border: 1px solid var(--border); transition: all 0.15s;
    }
    .speed-opt.active {
      background: var(--accent-dim); color: var(--accent);
      border-color: var(--accent);
    }

    /* ========== DESCRIPTION MODAL ========== */
    #desc-modal {
      position: fixed; inset: 0; z-index: 250;
      background: rgba(0,0,0,0.65); display: flex;
      align-items: center; justify-content: center; padding: 24px;
      opacity: 0; pointer-events: none; transition: opacity 0.2s;
    }
    #desc-modal.visible { opacity: 1; pointer-events: auto; }

    .desc-modal-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 0;
      width: 100%; max-width: 440px; display: flex; flex-direction: column;
      max-height: 80vh; overflow: hidden;
    }
    .desc-modal-header {
      padding: 20px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      flex-shrink: 0;
    }
    .desc-modal-title {
      font-size: 16px; font-weight: 700; flex: 1; min-width: 0;
    }
    .desc-modal-close {
      width: 32px; height: 32px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-2); font-size: 16px; flex-shrink: 0;
      margin-left: 8px;
    }
    .desc-modal-close:active { background: var(--surface-2); }
    .desc-modal-body {
      flex: 1; overflow-y: auto; padding: 20px;
      font-size: 14px; line-height: 1.6; color: var(--text);
    }
    .desc-modal-body p { margin-bottom: 12px; }
    .desc-modal-body br { display: block; content: ''; margin: 4px 0; }

    /* ========== TOASTS ========== */
    #toast-container {
      position: fixed; top: calc(16px + var(--safe-t)); left: 16px; right: 16px;
      z-index: 400; display: flex; flex-direction: column; gap: 8px;
      pointer-events: none;
    }
    .toast {
      padding: 12px 16px; border-radius: var(--radius-sm);
      background: var(--surface-2); border: 1px solid var(--border);
      font-size: 13px; font-weight: 500; pointer-events: auto;
      transform: translateY(-20px); opacity: 0;
      transition: transform 0.25s, opacity 0.25s;
    }
    .toast.visible { transform: translateY(0); opacity: 1; }
    .toast.success { border-color: var(--success); color: var(--success); }
    .toast.error { border-color: var(--error); color: var(--error); }

    /* ========== EMPTY STATE ========== */
    .empty-state {
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; padding: 60px 32px; text-align: center;
    }
    .empty-icon {
      width: 64px; height: 64px; border-radius: 50%;
      background: var(--surface-2); display: flex;
      align-items: center; justify-content: center;
      font-size: 24px; color: var(--text-3); margin-bottom: 16px;
    }
    .empty-title {
      font-size: 16px; font-weight: 700; margin-bottom: 6px;
    }
    .empty-sub {
      font-size: 13px; color: var(--text-3); line-height: 1.5; max-width: 260px;
    }

    /* ========== SKELETON ========== */
    .skel {
      border-radius: var(--radius-sm);
      background: linear-gradient(90deg, var(--surface-2) 25%, var(--surface-3) 50%, var(--surface-2) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
    }
    @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

    .skel-card { height: 80px; margin-bottom: 8px; border-radius: var(--radius); }

    /* ========== DOWNLOADS LIST ========== */
    .dl-item {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 14px 0; border-bottom: 1px solid var(--border);
    }
    .dl-item:last-child { border-bottom: none; }
    .dl-item-icon {
      width: 40px; height: 40px; border-radius: 50%;
      background: var(--accent-dim); color: var(--accent);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; flex-shrink: 0; position: relative;
    }
    .dl-item-icon.done { color: var(--success); background: rgba(74,222,128,0.1); }
    .dl-item-icon.failed { color: var(--error); background: rgba(248,113,113,0.1); }
    .dl-item-info { flex: 1; min-width: 0; }
    .dl-item-title {
      font-size: 14px; font-weight: 500; line-height: 1.3;
      white-space: normal; word-break: break-word; margin-bottom: 4px;
    }
    .dl-item-sub {
      font-size: 12px; color: var(--text-3); margin-bottom: 6px;
    }
    .dl-item-progress {
      width: 100%; height: 3px; border-radius: 2px;
      background: var(--surface-3); overflow: hidden; margin-bottom: 6px;
    }
    .dl-item-progress-fill {
      height: 100%; background: var(--accent); width: 0%;
      transition: width 0.2s;
    }
    .dl-item-actions {
      display: flex; gap: 8px; flex-shrink: 0; margin-top: 4px;
    }
    .dl-item-btn {
      padding: 6px 10px; border-radius: 6px; font-size: 12px; font-weight: 600;
      background: var(--surface-2); color: var(--text-2);
      transition: background 0.15s;
      display: flex; align-items: center; gap: 4px;
    }
    .dl-item-btn:active { background: var(--surface-3); }
    .dl-item-btn.delete { color: var(--error); }
    .dl-item-btn.saving { color: var(--accent); background: var(--accent-dim); }

    /* ========== UTILITY ========== */
    .hidden { display: none !important; }
    .spinner { animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* Subtle ambient glow */
    #app::before {
      content: ''; position: fixed; top: -30%; left: -20%;
      width: 60%; height: 60%; border-radius: 50%;
      background: radial-gradient(circle, rgba(232,115,74,0.04) 0%, transparent 70%);
      pointer-events: none; z-index: 0;
    }
  </style>
</head>
<body>
  <div id="app">
    <div id="views">
      <!-- SEARCH VIEW -->
      <section id="view-search" class="view active">
        <div class="view-header">
          <h1>Search</h1>
        </div>
        <div style="padding:0 20px 4px;">
          <div class="search-bar">
            <i class="fas fa-magnifying-glass"></i>
            <input type="text" id="search-input" placeholder="Find a podcast..." autocomplete="off">
            <button id="search-clear" class="search-clear"><i class="fas fa-xmark"></i></button>
          </div>
        </div>
        <div id="search-content" class="view-content">
          <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-podcast"></i></div>
            <div class="empty-title">Find your next listen</div>
            <div class="empty-sub">Search for any podcast by name, topic, or creator</div>
          </div>
        </div>
      </section>

      <!-- FOLLOWING VIEW -->
      <section id="view-following" class="view">
        <div class="view-header">
          <h1>Following</h1>
        </div>
        <div id="following-content" class="view-content">
          <div class="empty-state">
            <div class="empty-icon"><i class="far fa-heart"></i></div>
            <div class="empty-title">No followed podcasts</div>
            <div class="empty-sub">When you follow podcasts, their latest episodes will appear here</div>
          </div>
        </div>
      </section>

      <!-- DOWNLOADS VIEW -->
      <section id="view-downloads" class="view">
        <div class="view-header">
          <h1>Downloads</h1>
        </div>
        <div id="downloads-content" class="view-content">
          <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-circle-down"></i></div>
            <div class="empty-title">No downloads yet</div>
            <div class="empty-sub">Downloaded episodes will appear here</div>
          </div>
        </div>
      </section>

      <!-- SETTINGS VIEW -->
      <section id="view-settings" class="view">
        <div class="view-header">
          <h1>Settings</h1>
        </div>
        <div class="view-content">
          <div class="settings-section">
            <div class="settings-label">Playback</div>
            <div class="settings-group">
              <div class="settings-item">
                <span class="settings-item-label">Speed</span>
                <div id="speed-options" class="speed-options"></div>
              </div>
            </div>
          </div>
          <div class="settings-section">
            <div class="settings-label">Data</div>
            <div class="settings-group">
              <button class="settings-item-btn" onclick="clearSearchHistory()">Clear search history</button>
              <button class="settings-item-btn" onclick="clearFollows()">Clear followed podcasts</button>
              <button class="settings-item-btn" onclick="clearDownloads()">Clear all downloads</button>
            </div>
          </div>
          <div class="settings-section">
            <div class="settings-label">About</div>
            <div class="settings-group">
              <div class="settings-item">
                <span class="settings-item-label">Podflow</span>
                <span class="settings-item-value">v1.0</span>
              </div>
              <div class="settings-item">
                <span class="settings-item-label">Search API</span>
                <span class="settings-item-value">iTunes</span>
              </div>
              <div class="settings-item">
                <span class="settings-item-label">RSS Parsing</span>
                <span class="settings-item-value">Client-side</span>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- MINI PLAYER -->
    <div id="mini-player">
      <div class="mini-progress"><div id="mini-progress-fill" class="mini-progress-fill"></div></div>
      <div class="mini-inner" onclick="openFullPlayer()">
        <img id="mini-art" class="mini-art" src="" alt="">
        <div class="mini-info">
          <div id="mini-title" class="mini-title">Not playing</div>
          <div id="mini-sub" class="mini-sub">--</div>
        </div>
        <button class="mini-play" id="mini-play-btn" onclick="event.stopPropagation();togglePlayback()">
          <i class="fas fa-play" id="mini-play-icon"></i>
        </button>
      </div>
    </div>

    <!-- TAB BAR -->
    <nav id="tab-bar">
      <button class="tab-btn active" data-tab="search" aria-label="Search">
        <i class="fas fa-magnifying-glass"></i><span>Search</span>
      </button>
      <button class="tab-btn" data-tab="following" aria-label="Following">
        <i class="fas fa-heart"></i><span>Following</span>
      </button>
      <button class="tab-btn" data-tab="downloads" aria-label="Downloads">
        <i class="fas fa-circle-down"></i><span>Downloads</span>
      </button>
      <button class="tab-btn" data-tab="settings" aria-label="Settings">
        <i class="fas fa-gear"></i><span>Settings</span>
      </button>
    </nav>
  </div>

  <!-- PODCAST DETAIL OVERLAY -->
  <div id="podcast-detail">
    <div class="detail-header">
      <button class="detail-back" onclick="closePodcastDetail()" aria-label="Back"><i class="fas fa-chevron-left"></i></button>
      <span id="detail-header-title" class="detail-header-title">Podcast</span>
      <button id="detail-follow-btn" class="detail-follow-btn" onclick="toggleFollowFromDetail()"></button>
    </div>
    <div id="detail-hero" class="detail-hero"></div>
    <div id="detail-actions" class="detail-actions"></div>
    <div class="detail-eps">
      <div id="detail-eps-title" class="detail-eps-title">Episodes</div>
      <div id="detail-eps-list"></div>
    </div>
  </div>

  <!-- FULL PLAYER OVERLAY -->
  <div id="full-player">
    <div class="fp-header">
      <button onclick="closeFullPlayer()" aria-label="Minimize"><i class="fas fa-chevron-down"></i></button>
      <span>Now Playing</span>
      <button onclick="closeFullPlayer()" aria-label="Close"><i class="fas fa-xmark"></i></button>
    </div>
    <div class="fp-body">
      <img id="fp-artwork" class="fp-artwork" src="" alt="">
      <div class="fp-info">
        <div id="fp-title" class="fp-title">--</div>
        <div id="fp-podcast" class="fp-podcast">--</div>
      </div>
      <div class="fp-seek">
        <input type="range" id="fp-seek-bar" min="0" max="1000" value="0">
        <div class="fp-times">
          <span id="fp-time-current">0:00</span>
          <span id="fp-time-duration">0:00</span>
        </div>
      </div>
      <div class="fp-controls">
        <button class="fp-ctrl small" onclick="seekRelative(-15)" aria-label="Rewind 15s"><i class="fas fa-rotate-left"></i></button>
        <button class="fp-play" id="fp-play-btn" onclick="togglePlayback()" aria-label="Play/Pause"><i class="fas fa-play" id="fp-play-icon"></i></button>
        <button class="fp-ctrl small" onclick="seekRelative(30)" aria-label="Forward 30s"><i class="fas fa-rotate-right"></i></button>
      </div>
      <button class="fp-speed" id="fp-speed-btn" onclick="cycleSpeed()">1x</button>
      <div class="fp-bottom-actions" id="fp-bottom-actions" style="display:none">
        <button class="fp-action-btn" id="fp-download-btn" onclick="downloadCurrentEpisode()">
          <i class="fas fa-download"></i>
          <span>Download</span>
        </button>
      </div>
    </div>
  </div>

  <!-- DESCRIPTION MODAL -->
  <div id="desc-modal">
    <div class="desc-modal-card">
      <div class="desc-modal-header">
        <div class="desc-modal-title" id="desc-modal-ep-title">Episode Title</div>
        <button class="desc-modal-close" onclick="closeDescModal()" aria-label="Close"><i class="fas fa-xmark"></i></button>
      </div>
      <div class="desc-modal-body" id="desc-modal-body"></div>
    </div>
  </div>

  <!-- TOAST CONTAINER -->
  <div id="toast-container"></div>

  <audio id="audio" preload="metadata"></audio>

  <script>
    // ========================================
    // CONFIGURATION
    // ========================================
    const PROXIES = [];
    const SPEEDS = [0.5, 0.75, 1, 1.25, 1.5, 2];
    const MAX_FEED_EPISODES = 5;

    // ========================================
    // STATE
    // ========================================
    const state = {
      currentTab: 'search',
      follows: JSON.parse(localStorage.getItem('pf_follows') || '[]'),
      downloads: JSON.parse(localStorage.getItem('pf_downloads') || '[]'),
      downloadHistory: JSON.parse(localStorage.getItem('pf_download_history') || '[]'),
      searchHistory: JSON.parse(localStorage.getItem('pf_search_history') || '[]'),
      speed: parseFloat(localStorage.getItem('pf_speed') || '1'),
      currentPodcast: null,
      currentEpisodes: [],
      currentEpisode: null,
      isPlaying: false,
      downloadingUrls: new Set(),
    };

    // ========================================
    // DOM REFERENCES
    // ========================================
    const $ = id => document.getElementById(id);
    const audio = $('audio');

    // ========================================
    // UTILITIES
    // ========================================

    async function fetchWithProxy(url) {
      try {
        const r = await fetch(url);
        if (r.ok) return r;
      } catch(e) {}
      for (const proxy of PROXIES) {
        try {
          const r = await fetch(proxy + encodeURIComponent(url));
          if (r.ok) return r;
        } catch(e) { continue; }
      }
      throw new Error('Fetch failed');
    }

    function parseRSS(xmlText) {
      const parser = new DOMParser();
      const doc = parser.parseFromString(xmlText, 'text/xml');
      if (doc.querySelector('parsererror')) throw new Error('Invalid XML');
      const channel = doc.querySelector('channel');
      if (!channel) throw new Error('No channel found');

      const title = channel.querySelector('title')?.textContent || 'Unknown';
      const imgEl = channel.querySelector('image url') || channel.querySelector('itunes\\:image, image[href]');
      const image = imgEl?.textContent || imgEl?.getAttribute('href') || '';
      const artist = channel.querySelector('itunes\\:author')?.textContent || '';

      const items = doc.querySelectorAll('item');
      const episodes = Array.from(items).map(item => {
        const enc = item.querySelector('enclosure');
        const dur = item.querySelector('itunes\\:duration')?.textContent || '';
        const description = item.querySelector('description')?.textContent || item.querySelector('content\\:encoded')?.textContent || '';
        return {
          title: item.querySelector('title')?.textContent || 'Untitled',
          url: enc?.getAttribute('url') || '',
          date: item.querySelector('pubDate')?.textContent || '',
          duration: dur,
          description: description,
        };
      }).filter(ep => ep.url);

      return { title, image, artist, episodes };
    }

    function formatDate(dateStr) {
      if (!dateStr) return '';
      try {
        const d = new Date(dateStr);
        if (isNaN(d)) return dateStr;
        const now = new Date();
        const diff = Math.floor((now - d) / 86400000);
        if (diff === 0) return 'Today';
        if (diff === 1) return 'Yesterday';
        if (diff < 7) return `${diff}d ago`;
        return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: d.getFullYear() !== now.getFullYear() ? 'numeric' : undefined });
      } catch(e) { return dateStr; }
    }

    function formatDuration(dur) {
      if (!dur) return '';
      if (dur.includes(':')) return dur;
      const s = parseInt(dur);
      if (isNaN(s)) return '';
      const h = Math.floor(s / 3600);
      const m = Math.floor((s % 3600) / 60);
      if (h > 0) return `${h}h ${m}m`;
      return `${m} min`;
    }

    function formatTime(sec) {
      if (isNaN(sec) || sec < 0) return '0:00';
      const m = Math.floor(sec / 60);
      const s = Math.floor(sec % 60);
      return `${m}:${s.toString().padStart(2, '0')}`;
    }

    function getAudioExt(url) {
      try {
        const p = new URL(url).pathname;
        const ext = p.split('.').pop().toLowerCase();
        if (['mp3','m4a','wav','ogg','opus','flac','aac'].includes(ext)) return ext;
      } catch(e) {}
      return 'mp3';
    }

    function sanitize(name) {
      return name.replace(/[^a-z0-9_\-\s]/gi, '').replace(/\s+/g, '_').substring(0, 120);
    }

    function saveState() {
      localStorage.setItem('pf_follows', JSON.stringify(state.follows));
      localStorage.setItem('pf_downloads', JSON.stringify(state.downloads));
      localStorage.setItem('pf_download_history', JSON.stringify(state.downloadHistory));
      localStorage.setItem('pf_search_history', JSON.stringify(state.searchHistory));
      localStorage.setItem('pf_speed', state.speed.toString());
    }

    function showToast(msg, type = '') {
      const t = document.createElement('div');
      t.className = `toast ${type}`;
      t.textContent = msg;
      $('toast-container').appendChild(t);
      requestAnimationFrame(() => t.classList.add('visible'));
      setTimeout(() => {
        t.classList.remove('visible');
        setTimeout(() => t.remove(), 300);
      }, 2500);
    }

    function isFollowing(rss) {
      return state.follows.some(f => f.rss === rss);
    }

    // ========================================
    // SEARCH
    // ========================================

    async function searchPodcasts(query) {
      if (!query.trim()) {
        $('search-content').innerHTML = '<div class="empty-state"><div class="empty-icon"><i class="fas fa-podcast"></i></div><div class="empty-title">Find your next listen</div><div class="empty-sub">Search for any podcast by name, topic, or creator</div></div>';
        return;
      }

      $('search-content').innerHTML = '<div class="skel-card"></div><div class="skel-card"></div><div class="skel-card"></div>';

      try {
        const r = await fetch(`https://itunes.apple.com/search?term=${encodeURIComponent(query)}&media=podcast&limit=20`);
        const data = await r.json();
        
        if (!data.results || data.results.length === 0) {
          $('search-content').innerHTML = '<div class="empty-state"><div class="empty-icon"><i class="fas fa-search"></i></div><div class="empty-title">No results found</div><div class="empty-sub">Try searching with different keywords</div></div>';
          return;
        }

        let html = '';
        for (const item of data.results) {
          const rss = item.feedUrl;
          const title = item.collectionName;
          const image = item.artworkUrl100;
          const artist = item.artistName;

          html += `
            <div class="pod-card" onclick="openPodcastDetail('${rss.replace(/'/g, "\\'")}', '${title.replace(/'/g, "\\'")}', '${image}', '${artist.replace(/'/g, "\\'")}')" >
              <img class="pod-card-art" src="${image}" alt="${title}">
              <div class="pod-card-info">
                <div class="pod-card-title">${title}</div>
                <div class="pod-card-artist">${artist}</div>
              </div>
              <i class="fas fa-chevron-right pod-card-chevron"></i>
            </div>
          `;
        }
        $('search-content').innerHTML = html;

        // Add to search history
        if (!state.searchHistory.includes(query)) {
          state.searchHistory.unshift(query);
          if (state.searchHistory.length > 20) state.searchHistory.pop();
          saveState();
        }
      } catch(e) {
        $('search-content').innerHTML = '<div class="empty-state"><div class="empty-icon"><i class="fas fa-exclamation-circle"></i></div><div class="empty-title">Search failed</div><div class="empty-sub">' + (e.message || 'Please try again') + '</div></div>';
      }
    }

    $('search-input').addEventListener('input', (e) => {
      const q = e.target.value.trim();
      $('search-clear').classList.toggle('visible', q.length > 0);
      if (q.length > 0) searchPodcasts(q);
    });

    $('search-clear').addEventListener('click', () => {
      $('search-input').value = '';
      $('search-clear').classList.remove('visible');
      $('search-content').innerHTML = '<div class="empty-state"><div class="empty-icon"><i class="fas fa-podcast"></i></div><div class="empty-title">Find your next listen</div><div class="empty-sub">Search for any podcast by name, topic, or creator</div></div>';
    });

    // ========================================
    // PODCAST DETAIL
    // ========================================

    async function openPodcastDetail(rss, title, image, artist) {
      $('podcast-detail').classList.add('open');
      $('detail-header-title').textContent = title;
      
      const following = isFollowing(rss);
      const btn = $('detail-follow-btn');
      btn.className = following ? 'detail-follow-btn following' : 'detail-follow-btn not-following';
      btn.innerHTML = following ? '<i class="fas fa-heart-solid"></i><span>Following</span>' : '<i class="fas fa-heart"></i><span>Follow</span>';
      btn.onclick = () => toggleFollow(rss, title, image, artist);

      $('detail-hero').innerHTML = `
        <img class="detail-art" src="${image}" alt="${title}">
        <div class="detail-hero-info">
          <div class="detail-hero-title">${title}</div>
          <div class="detail-hero-artist">${artist}</div>
          <div class="detail-hero-count">--episodes</div>
        </div>
      `;

      $('detail-actions').innerHTML = `
        <button class="action-btn primary" onclick="playFromDetail()">
          <i class="fas fa-play"></i>
          <span>Play Latest</span>
        </button>
        <button class="action-btn secondary" onclick="shareDetail()">
          <i class="fas fa-share"></i>
          <span>Share</span>
        </button>
      `;

      $('detail-eps-list').innerHTML = '<div class="skel-card"></div><div class="skel-card"></div>';

      try {
        const r = await fetch('https://api.allorigins.win/get?url=' + encodeURIComponent(rss));
        const data = await r.json();
        const feed = parseRSS(data.contents);
        state.currentPodcast = { rss, title: feed.title, image: feed.image, artist: feed.artist };
        state.currentEpisodes = feed.episodes;

        $('detail-hero-count').textContent = feed.episodes.length + ' episodes';

        let html = '';
        for (const ep of feed.episodes.slice(0, 50)) {
          html += `
            <div class="ep-item">
              <button class="ep-play-btn" onclick="playEpisode('${ep.url.replace(/'/g, "\\'")}', '${ep.title.replace(/'/g, "\\'")}', '${feed.image}', '${feed.title.replace(/'/g, "\\'")}')" >
                <i class="fas fa-play"></i>
              </button>
              <div class="ep-info" onclick="showEpisodeDesc('${ep.title.replace(/'/g, "\\'")}', '${ep.description.replace(/'/g, "\\'").replace(/\n/g, '<br>')}')">
                <div class="ep-title">${ep.title}</div>
                <div class="ep-meta">
                  <span>${formatDate(ep.date)}</span>
                  <span>${formatDuration(ep.duration)}</span>
                </div>
              </div>
              <button class="ep-dl-btn" onclick="downloadEpisode('${ep.url.replace(/'/g, "\\'")}', '${ep.title.replace(/'/g, "\\'")}')">
                <i class="fas fa-download"></i>
              </button>
            </div>
          `;
        }
        $('detail-eps-list').innerHTML = html;
      } catch(e) {
        $('detail-eps-list').innerHTML = '<div class="empty-state"><div class="empty-icon"><i class="fas fa-exclamation-circle"></i></div><div class="empty-title">Failed to load episodes</div></div>';
      }
    }

    function closePodcastDetail() {
      $('podcast-detail').classList.remove('open');
    }

    function toggleFollow(rss, title, image, artist) {
      const idx = state.follows.findIndex(f => f.rss === rss);
      if (idx >= 0) {
        state.follows.splice(idx, 1);
        showToast('Unfollowed');
      } else {
        state.follows.push({ rss, title, image, artist });
        showToast('Following podcast', 'success');
      }
      saveState();
      renderFollowing();
      const following = isFollowing(rss);
      const btn = $('detail-follow-btn');
      btn.className = following ? 'detail-follow-btn following' : 'detail-follow-btn not-following';
      btn.innerHTML = following ? '<i class="fas fa-heart-solid"></i><span>Following</span>' : '<i class="fas fa-heart"></i><span>Follow</span>';
    }

    function toggleFollowFromDetail() {
      if (state.currentPodcast) {
        toggleFollow(state.currentPodcast.rss, state.currentPodcast.title, state.currentPodcast.image, state.currentPodcast.artist);
      }
    }

    function playFromDetail() {
      if (state.currentEpisodes.length > 0) {
        const ep = state.currentEpisodes[0];
        playEpisode(ep.url, ep.title, state.currentPodcast.image, state.currentPodcast.title);
      }
    }

    function shareDetail() {
      if (state.currentPodcast && navigator.share) {
        navigator.share({
          title: state.currentPodcast.title,
          text: 'Check out this podcast',
          url: state.currentPodcast.rss
        }).catch(() => {});
      }
    }

    // ========================================
    // PLAYBACK
    // ========================================

    function playEpisode(url, title, image, podcast) {
      state.currentEpisode = { url, title, image, podcast };
      audio.src = url;
      audio.play();
      state.isPlaying = true;
      updatePlayer();
      showToast('Now playing: ' + title);
    }

    function togglePlayback() {
      if (!state.currentEpisode) return;
      if (state.isPlaying) {
        audio.pause();
        state.isPlaying = false;
      } else {
        audio.play();
        state.isPlaying = true;
      }
      updatePlayer();
    }

    function seekRelative(sec) {
      audio.currentTime = Math.max(0, audio.currentTime + sec);
    }

    function cycleSpeed() {
      const idx = SPEEDS.indexOf(state.speed);
      state.speed = SPEEDS[(idx + 1) % SPEEDS.length];
      audio.playbackRate = state.speed;
      $('fp-speed-btn').textContent = state.speed + 'x';
      saveState();
    }

    function updatePlayer() {
      const hasEp = !!state.currentEpisode;
      $('mini-player').classList.toggle('visible', hasEp);
      if (!hasEp) return;

      const ep = state.currentEpisode;
      $('mini-title').textContent = ep.title;
      $('mini-sub').textContent = ep.podcast;
      $('mini-art').src = ep.image;
      $('fp-artwork').src = ep.image;
      $('fp-title').textContent = ep.title;
      $('fp-podcast').textContent = ep.podcast;

      const icon = state.isPlaying ? 'fa-pause' : 'fa-play';
      $('mini-play-icon').className = `fas ${icon}`;
      $('fp-play-icon').className = `fas ${icon}`;
    }

    audio.addEventListener('timeupdate', () => {
      const dur = audio.duration || 1;
      $('fp-time-current').textContent = formatTime(audio.currentTime);
      $('fp-time-duration').textContent = formatTime(dur);
      $('fp-seek-bar').max = Math.ceil(dur);
      $('fp-seek-bar').value = Math.ceil(audio.currentTime);
      $('mini-progress-fill').style.width = (audio.currentTime / dur * 100) + '%';
    });

    audio.addEventListener('play', () => {
      state.isPlaying = true;
      updatePlayer();
    });

    audio.addEventListener('pause', () => {
      state.isPlaying = false;
      updatePlayer();
    });

    $('fp-seek-bar').addEventListener('input', (e) => {
      audio.currentTime = e.target.value;
    });

    function openFullPlayer() {
      if (state.currentEpisode) $('full-player').classList.add('open');
    }

    function closeFullPlayer() {
      $('full-player').classList.remove('open');
    }

    // ========================================
    // DESCRIPTION MODAL
    // ========================================

    function showEpisodeDesc(title, description) {
      $('desc-modal-ep-title').textContent = title;
      $('desc-modal-body').innerHTML = description;
      $('desc-modal').classList.add('visible');
    }

    function closeDescModal() {
      $('desc-modal').classList.remove('visible');
    }

    // ========================================
    // DOWNLOADS
    // ========================================

    async function downloadEpisode(url, title) {
      if (state.downloadingUrls.has(url)) return;
      state.downloadingUrls.add(url);
      showToast('Downloading...');

      try {
        const r = await fetch(url);
        const blob = await r.blob();
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = sanitize(title) + '.' + getAudioExt(url);
        a.click();

        state.downloads.push({ title, url, date: new Date().toISOString() });
        state.downloadHistory.push(url);
        saveState();
        showToast('Downloaded!', 'success');
      } catch(e) {
        showToast('Download failed', 'error');
      }
      
      state.downloadingUrls.delete(url);
    }

    function downloadCurrentEpisode() {
      if (state.currentEpisode) {
        downloadEpisode(state.currentEpisode.url, state.currentEpisode.title);
      }
    }

    // ========================================
    // FOLLOWING & FEED
    // ========================================

    function renderFollowing() {
      if (state.follows.length === 0) {
        $('following-content').innerHTML = '<div class="empty-state"><div class="empty-icon"><i class="far fa-heart"></i></div><div class="empty-title">No followed podcasts</div><div class="empty-sub">When you follow podcasts, their latest episodes will appear here</div></div>';
        return;
      }

      let html = '';
      for (const follow of state.follows) {
        html += `
          <div style="cursor:pointer" onclick="openPodcastDetail('${follow.rss.replace(/'/g, "\\'")}', '${follow.title.replace(/'/g, "\\'")}', '${follow.image}', '${follow.artist.replace(/'/g, "\\'")}')" >
            <div class="feed-ep">
              <img class="feed-ep-art" src="${follow.image}" alt="${follow.title}">
              <div class="feed-ep-info">
                <div class="feed-ep-pod">${follow.title}</div>
                <div class="feed-ep-title">Latest episodes</div>
                <div class="feed-ep-meta"><span>${follow.artist}</span></div>
              </div>
            </div>
          </div>
        `;
      }
      $('following-content').innerHTML = html;
    }

    // ========================================
    // SETTINGS
    // ========================================

    function renderSettings() {
      const speedOpts = SPEEDS.map(s => `
        <button class="speed-opt ${s === state.speed ? 'active' : ''}" onclick="setSpeed(${s})">${s}x</button>
      `).join('');
      $('speed-options').innerHTML = speedOpts;
    }

    function setSpeed(s) {
      state.speed = s;
      audio.playbackRate = s;
      saveState();
      renderSettings();
      $('fp-speed-btn').textContent = s + 'x';
    }

    function clearSearchHistory() {
      if (confirm('Clear search history?')) {
        state.searchHistory = [];
        saveState();
        showToast('Cleared', 'success');
      }
    }

    function clearFollows() {
      if (confirm('Unfollow all podcasts?')) {
        state.follows = [];
        saveState();
        renderFollowing();
        showToast('Cleared', 'success');
      }
    }

    function clearDownloads() {
      if (confirm('Clear downloads list?')) {
        state.downloads = [];
        saveState();
        showToast('Cleared', 'success');
      }
    }

    // ========================================
    // TAB NAVIGATION
    // ========================================

    function switchTab(tab) {
      state.currentTab = tab;
      document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      $('view-' + tab).classList.add('active');
      document.querySelector(`[data-tab="${tab}"]`).classList.add('active');

      if (tab === 'following') renderFollowing();
      if (tab === 'settings') renderSettings();
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn.dataset.tab));
    });

    // ========================================
    // INIT
    // ========================================

    renderSettings();
    renderFollowing();
    audio.playbackRate = state.speed;

  </script>
</body>
</html>