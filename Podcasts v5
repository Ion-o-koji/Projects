  <!-- DOWNLOAD MODAL -->
  <div id="download-modal" class="modal-overlay">
    <div class="modal-card">
      <h3 id="dl-modal-title">Downloading</h3>
      <div class="modal-progress-bar"><div id="dl-modal-fill" class="modal-progress-fill"></div></div>
      <div id="dl-modal-sub" class="modal-sub">0 of 0</div>
      <div id="dl-modal-detail" class="modal-detail">--</div>
      <button class="modal-cancel" id="dl-modal-cancel" onclick="cancelDownloadAll()">Cancel</button>
    </div>
  </div>

  <!-- TOAST CONTAINER -->
  <div id="toast-container"></div>

  <audio id="audio" preload="metadata"></audio>

  <script>
    // ========================================
    // CONFIGURATION
    // ========================================
    const PROXIES = [];
    const SPEEDS = [0.5, 0.75, 1, 1.25, 1.5, 2];
    const MAX_FEED_EPISODES = 5;

    // ========================================
    // STATE
    // ========================================
    const state = {
      currentTab: 'search',
      follows: JSON.parse(localStorage.getItem('pf_follows') || '[]'),
      downloads: JSON.parse(localStorage.getItem('pf_downloads') || '[]'),
      searchHistory: JSON.parse(localStorage.getItem('pf_search_history') || '[]'),
      speed: parseFloat(localStorage.getItem('pf_speed') || '1'),
      currentPodcast: null,
      currentEpisodes: [],
      currentEpisode: null,
      isPlaying: false,
      savingDownloads: new Set(),
    };

    // ========================================
    // DOM REFERENCES
    // ========================================
    const $ = id => document.getElementById(id);
    const audio = $('audio');

    // ========================================
    // UTILITIES
    // ========================================

    async function fetchWithProxy(url) {
      try {
        const r = await fetch(url);
        if (r.ok) return r;
      } catch(e) {}
      for (const proxy of PROXIES) {
        try {
          const r = await fetch(proxy + encodeURIComponent(url));
          if (r.ok) return r;
        } catch(e) { continue; }
      }
      throw new Error('Fetch failed');
    }

    function parseRSS(xmlText) {
      const parser = new DOMParser();
      const doc = parser.parseFromString(xmlText, 'text/xml');
      if (doc.querySelector('parsererror')) throw new Error('Invalid XML');
      const channel = doc.querySelector('channel');
      if (!channel) throw new Error('No channel found');

      const title = channel.querySelector('title')?.textContent || 'Unknown';
      const imgEl = channel.querySelector('image url') || channel.querySelector('itunes\\:image, image[href]');
      const image = imgEl?.textContent || imgEl?.getAttribute('href') || '';
      const artist = channel.querySelector('itunes\\:author')?.textContent || '';

      const items = doc.querySelectorAll('item');
      const episodes = Array.from(items).map(item => {
        const enc = item.querySelector('enclosure');
        const dur = item.querySelector('itunes\\:duration')?.textContent || '';
        return {
          title: item.querySelector('title')?.textContent || 'Untitled',
          url: enc?.getAttribute('url') || '',
          date: item.querySelector('pubDate')?.textContent || '',
          duration: dur,
        };
      }).filter(ep => ep.url);

      return { title, image, artist, episodes };
    }

    function formatDate(dateStr) {
      if (!dateStr) return '';
      try {
        const d = new Date(dateStr);
        if (isNaN(d)) return dateStr;
        const now = new Date();
        const diff = Math.floor((now - d) / 86400000);
        if (diff === 0) return 'Today';
        if (diff === 1) return 'Yesterday';
        if (diff < 7) return `${diff}d ago`;
        return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: d.getFullYear() !== now.getFullYear() ? 'numeric' : undefined });
      } catch(e) { return dateStr; }
    }

    function formatDuration(dur) {
      if (!dur) return '';
      if (dur.includes(':')) return dur;
      const s = parseInt(dur);
      if (isNaN(s)) return '';
      const h = Math.floor(s / 3600);
      const m = Math.floor((s % 3600) / 60);
      if (h > 0) return `${h}h ${m}m`;
      return `${m} min`;
    }

    function formatTime(sec) {
      if (isNaN(sec) || sec < 0) return '0:00';
      const m = Math.floor(sec / 60);
      const s = Math.floor(sec % 60);
      return `${m}:${s.toString().padStart(2, '0')}`;
    }

    function getAudioExt(url) {
      try {
        const p = new URL(url).pathname;
        const ext = p.split('.').pop().toLowerCase();
        if (['mp3','m4a','wav','ogg','opus','flac','aac'].includes(ext)) return ext;
      } catch(e) {}
      return 'mp3';
    }

    function sanitize(name) {
      return name.replace(/[^a-z0-9_\-\s]/gi, '').replace(/\s+/g, '_').substring(0, 120);
    }

    function saveState() {
      localStorage.setItem('pf_follows', JSON.stringify(state.follows));
      localStorage.setItem('pf_downloads', JSON.stringify(state.downloads));
      localStorage.setItem('pf_search_history', JSON.stringify(state.searchHistory));
      localStorage.setItem('pf_speed', state.speed.toString());
    }

    function showToast(msg, type = '') {
      const t = document.createElement('div');
      t.className = `toast ${type}`;
      t.textContent = msg;
      $('toast-container').appendChild(t);
      requestAnimationFrame(() => t.classList.add('visible'));
      setTimeout(() => {
        t.classList.remove('visible');
        setTimeout(() => t.remove(), 300);
      }, 2500);
    }

    function isFollowing(rss) {
      return state.follows.some(f => f.rss === rss);
    }

    function escAttr(s) {
      return s.replace(/&/g,'&amp;').replace(/'/g,'&#39;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function generateDownloadId(url, title) {
      return `dl_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
    }

    function isDownloaded(url) {
      return state.downloads.some(d => d.url === url && d.status === 'done');
    }

    // ========================================
    // DOWNLOAD SYSTEM
    // ========================================

    async function startDownload(url, title, podcastTitle, podcastImage, date, duration) {
      const dlId = generateDownloadId(url, title);
      const ext = getAudioExt(url);
      
      const dlEntry = {
        id: dlId,
        url,
        title,
        podcastTitle,
        podcastImage,
        date,
        duration,
        ext,
        status: 'downloading',
        progress: 0,
        blob: null,
        timestamp: Date.now(),
        error: null
      };
      
      state.downloads.push(dlEntry);
      saveState();
      
      updateDownloadButtonForUrl(url);
      renderDownloads();
      showToast('Download started', '');
      
      try {
        const response = await fetchWithProxy(url);
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        
        const contentLength = parseInt(response.headers.get('content-length') || '0', 10);
        const reader = response.body.getReader();
        const chunks = [];
        let received = 0;
        
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          chunks.push(value);
          received += value.length;
          
          dlEntry.progress = contentLength > 0 ? Math.round((received / contentLength) * 100) : 0;
          updateDownloadButtonForUrl(url);
          renderDownloads();
        }
        
        const blob = new Blob(chunks, { type: 'audio/*' });
        dlEntry.blob = blob;
        dlEntry.status = 'done';
        dlEntry.progress = 100;
        
      } catch (err) {
        dlEntry.status = 'failed';
        dlEntry.error = err.message || 'Download failed';
        showToast('Download failed', 'error');
      }
      
      saveState();
      updateDownloadButtonForUrl(url);
      renderDownloads();
    }

    function updateDownloadButtonForUrl(url) {
      const dlBtn = document.querySelector(`[data-dl-url="${escAttr(url)}"]`);
      if (!dlBtn) return;
      
      const dl = state.downloads.find(d => d.url === url);
      if (!dl) {
        dlBtn.className = 'ep-dl-btn';
        dlBtn.innerHTML = '<i class="fas fa-download"></i>';
        dlBtn.disabled = false;
        return;
      }
      
      if (dl.status === 'downloading') {
        dlBtn.className = 'ep-dl-btn staging';
        dlBtn.innerHTML = `<i class="fas fa-spinner fa-spin"></i>`;
        dlBtn.disabled = true;
      } else if (dl.status === 'done') {
        dlBtn.className = 'ep-dl-btn done';
        dlBtn.innerHTML = '<i class="fas fa-check"></i>';
        dlBtn.disabled = false;
      } else if (dl.status === 'failed') {
        dlBtn.className = 'ep-dl-btn failed';
        dlBtn.innerHTML = '<i class="fas fa-exclamation"></i>';
        dlBtn.disabled = false;
      }
    }

    async function saveDownloadToDevice(dlId) {
      const dl = state.downloads.find(d => d.id === dlId);
      if (!dl || !dl.blob) {
        showToast('Download not ready', 'error');
        return;
      }
      
      state.savingDownloads.add(dlId);
      renderDownloads();
      
      try {
        const filename = `${sanitize(dl.title)}.${dl.ext}`;
        
        if ('showSaveFilePicker' in window) {
          const handle = await window.showSaveFilePicker({
            suggestedName: filename,
            types: [{ description: 'Audio File', accept: { 'audio/*': [`.${dl.ext}`] } }]
          });
          const writable = await handle.createWritable();
          await writable.write(dl.blob);
          await writable.close();
        } else {
          const url = URL.createObjectURL(dl.blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = filename;
          a.click();
          URL.revokeObjectURL(url);
        }
        
        state.savingDownloads.delete(dlId);
        renderDownloads();
        showToast('Saved successfully', 'success');
      } catch (err) {
        state.savingDownloads.delete(dlId);
        renderDownloads();
        if (err.name !== 'AbortError') {
          showToast('Could not save file', 'error');
        }
      }
    }

    function deleteDownload(dlId) {
      const idx = state.downloads.findIndex(d => d.id === dlId);
      if (idx >= 0) {
        state.downloads.splice(idx, 1);
        saveState();
        renderDownloads();
        updateAllDownloadButtons();
        showToast('Download removed', '');
      }
    }

    function updateAllDownloadButtons() {
      state.downloads.forEach(dl => {
        updateDownloadButtonForUrl(dl.url);
      });
    }

    // ========================================
    // NAVIGATION
    // ========================================

    function switchTab(tab) {
      state.currentTab = tab;
      document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
      $(`view-${tab}`).classList.add('active');
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.tab === tab);
      });
      if (tab === 'following') loadFollowingFeed();
      if (tab === 'downloads') renderDownloads();
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn.dataset.tab));
    });

    // ========================================
    // SEARCH
    // ========================================

    const searchInput = $('search-input');
    const searchClear = $('search-clear');
    let searchTimeout;

    searchInput.addEventListener('input', () => {
      searchClear.classList.toggle('visible', searchInput.value.length > 0);
      clearTimeout(searchTimeout);
      if (searchInput.value.trim().length >= 2) {
        searchTimeout = setTimeout(() => doSearch(searchInput.value.trim()), 400);
      } else if (searchInput.value.length === 0) {
        renderSearchEmpty();
      }
    });

    searchInput.addEventListener('keydown', e => {
      if (e.key === 'Enter') {
        clearTimeout(searchTimeout);
        doSearch(searchInput.value.trim());
      }
    });

    searchClear.addEventListener('click', () => {
      searchInput.value = '';
      searchClear.classList.remove('visible');
      renderSearchEmpty();
      searchInput.focus();
    });

    function renderSearchEmpty() {
      if (state.searchHistory.length > 0) {
        $('search-content').innerHTML = `
          <div style="margin-bottom:12px">
            <div class="settings-label">Recent Searches</div>
            <div style="display:flex;flex-wrap:wrap;gap:8px">
              ${state.searchHistory.map(q => `
                <button onclick="doSearch('${escAttr(q)}')" style="padding:6px 14px;border-radius:20px;background:var(--surface);border:1px solid var(--border);font-size:13px;font-weight:500;color:var(--text-2);transition:background 0.15s">${escAttr(q)}</button>
              `).join('')}
            </div>
          </div>
        `;
      } else {
        $('search-content').innerHTML = `
          <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-podcast"></i></div>
            <div class="empty-title">Find your next listen</div>
            <div class="empty-sub">Search for any podcast by name, topic, or creator</div>
          </div>
        `;
      }
    }

    async function doSearch(q) {
      if (!q.trim()) return;
      
      if (!state.searchHistory.includes(q)) {
        state.searchHistory.unshift(q);
        if (state.searchHistory.length > 20) state.searchHistory.pop();
        saveState();
      }
      
      $('search-content').innerHTML = '<div style="padding:40px;text-align:center"><i class="fas fa-spinner fa-spin" style="font-size:24px;color:var(--text-3)"></i></div>';
      
      try {
        const res = await fetch(`https://itunes.apple.com/search?term=${encodeURIComponent(q)}&media=podcast&limit=50`);
        if (!res.ok) throw new Error('Search failed');
        const data = await res.json();
        const results = data.results || [];
        
        if (results.length === 0) {
          $('search-content').innerHTML = `
            <div class="empty-state">
              <div class="empty-icon"><i class="fas fa-search"></i></div>
              <div class="empty-title">No results</div>
              <div class="empty-sub">Try a different search term</div>
            </div>
          `;
          return;
        }
        
        $('search-content').innerHTML = results.map(pod => `
          <div class="pod-card" onclick="openPodcastDetail('${escAttr(pod.feedUrl)}', '${escAttr(pod.collectionName)}', '${escAttr(pod.artworkUrl600)}', '${escAttr(pod.artistName)}')">
            <img src="${pod.artworkUrl600}" alt="" class="pod-card-art" onerror="this.style.background='var(--surface-3)'">
            <div class="pod-card-info">
              <div class="pod-card-title">${escAttr(pod.collectionName)}</div>
              <div class="pod-card-artist">${escAttr(pod.artistName)}</div>
            </div>
            <i class="fas fa-chevron-right pod-card-chevron"></i>
          </div>
        `).join('');
      } catch (err) {
        $('search-content').innerHTML = `
          <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-exclamation-triangle"></i></div>
            <div class="empty-title">Search failed</div>
            <div class="empty-sub">Check your connection and try again</div>
          </div>
        `;
      }
    }

    // ========================================
    // PODCAST DETAIL
    // ========================================

    async function openPodcastDetail(rss, title, image, artist) {
      $('podcast-detail').classList.add('open');
      state.currentPodcast = { rss, title, image, artist };
      state.currentEpisodes = [];
      
      const following = isFollowing(rss);
      $('detail-follow-btn').className = `detail-follow-btn ${following ? 'following' : 'not-following'}`;
      $('detail-follow-btn').textContent = following ? '✓ Following' : '+ Follow';
      $('detail-header-title').textContent = title;
      
      $('detail-hero').innerHTML = `
        <img src="${image}" alt="" class="detail-art" onerror="this.style.background='var(--surface-3)'">
        <div class="detail-hero-info">
          <div class="detail-hero-title">${escAttr(title)}</div>
          <div class="detail-hero-artist">${escAttr(artist)}</div>
        </div>
      `;
      
      $('detail-eps-list').innerHTML = '<div style="text-align:center;padding:40px;"><i class="fas fa-spinner fa-spin" style="font-size:20px;color:var(--text-3)"></i></div>';
      
      try {
        const res = await fetchWithProxy(rss);
        const xml = await res.text();
        const parsed = parseRSS(xml);
        state.currentEpisodes = parsed.episodes;
        state.currentPodcast.image = parsed.image || image;
        
        $('detail-eps-list').innerHTML = state.currentEpisodes.map((ep, i) => `
          <div class="ep-item">
            <button class="ep-play-btn" onclick="playEpisode(${i})"><i class="fas fa-play"></i></button>
            <div class="ep-info">
              <div class="ep-title">${escAttr(ep.title)}</div>
              <div class="ep-meta">
                <span>${formatDate(ep.date)}</span>
                ${ep.duration ? `<span>${formatDuration(ep.duration)}</span>` : ''}
              </div>
            </div>
            <div style="position:relative">
              <button class="ep-dl-btn" data-dl-url="${escAttr(ep.url)}" onclick="event.stopPropagation(); startDownload('${escAttr(ep.url)}', '${escAttr(ep.title)}', '${escAttr(title)}', '${escAttr(image)}', '${escAttr(ep.date)}', '${escAttr(ep.duration)}')">
                <i class="fas fa-download"></i>
              </button>
              ${isDownloaded(ep.url) ? '<span style="position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;background:var(--success);display:flex;align-items:center;justify-content:center;font-size:10px;color:#fff"><i class="fas fa-check"></i></span>' : ''}
            </div>
          </div>
        `).join('');
        
        updateAllDownloadButtons();
      } catch (err) {
        $('detail-eps-list').innerHTML = `<div class="empty-state"><div class="empty-icon"><i class="fas fa-exclamation-triangle"></i></div><div class="empty-title">Load failed</div></div>`;
      }
    }

    function closePodcastDetail() {
      $('podcast-detail').classList.remove('open');
    }

    function toggleFollowFromDetail() {
      if (!state.currentPodcast) return;
      const { rss, title, image, artist } = state.currentPodcast;
      const idx = state.follows.findIndex(f => f.rss === rss);
      
      if (idx >= 0) {
        state.follows.splice(idx, 1);
      } else {
        state.follows.push({ rss, title, image, artist });
      }
      
      saveState();
      const following = idx < 0;
      $('detail-follow-btn').className = `detail-follow-btn ${following ? 'following' : 'not-following'}`;
      $('detail-follow-btn').textContent = following ? '✓ Following' : '+ Follow';
      showToast(following ? 'Added to following' : 'Removed from following', '');
    }

    // ========================================
    // PLAYBACK
    // ========================================

    function playEpisode(idx) {
      const ep = state.currentEpisodes[idx];
      if (!ep || !ep.url) return;
      
      state.currentEpisode = ep;
      audio.src = ep.url;
      audio.play().catch(e => showToast('Playback failed', 'error'));
      state.isPlaying = true;
      
      updatePlayerUI();
      $('mini-player').classList.add('visible');
      $('fp-bottom-actions').style.display = 'flex';
      updateDownloadButtonForUrl(ep.url);
    }

    function updatePlayerUI() {
      const ep = state.currentEpisode;
      if (!ep) return;
      
      const art = state.currentPodcast?.image || '';
      $('mini-art').src = art;
      $('mini-title').textContent = ep.title;
      $('mini-sub').textContent = state.currentPodcast?.title || '--';
      
      $('fp-artwork').src = art;
      $('fp-title').textContent = ep.title;
      $('fp-podcast').textContent = state.currentPodcast?.title || '--';
    }

    function openFullPlayer() {
      $('full-player').classList.add('open');
    }

    function closeFullPlayer() {
      $('full-player').classList.remove('open');
    }

    function togglePlayback() {
      if (!state.currentEpisode && audio.src === '') return;
      
      if (state.isPlaying) {
        audio.pause();
        state.isPlaying = false;
      } else {
        audio.play().catch(e => showToast('Playback failed', 'error'));
        state.isPlaying = true;
      }
      updatePlayIcon();
    }

    function updatePlayIcon() {
      const icon = state.isPlaying ? 'fa-pause' : 'fa-play';
      $('mini-play-icon').className = `fas ${icon}`;
      $('fp-play-icon').className = `fas ${icon}`;
    }

    function seekRelative(seconds) {
      if (isNaN(audio.duration)) return;
      audio.currentTime = Math.max(0, Math.min(audio.duration, audio.currentTime + seconds));
    }

    function cycleSpeed() {
      const idx = SPEEDS.indexOf(state.speed);
      state.speed = SPEEDS[(idx + 1) % SPEEDS.length];
      audio.playbackRate = state.speed;
      $('fp-speed-btn').textContent = `${state.speed}x`;
      saveState();
    }

    function downloadCurrentEpisode() {
      if (!state.currentEpisode || !state.currentEpisode.url) return;
      startDownload(state.currentEpisode.url, state.currentEpisode.title, state.currentPodcast?.title || 'Unknown', state.currentPodcast?.image || '', state.currentEpisode.date || '', state.currentEpisode.duration || '');
    }

    // ========================================
    // DOWNLOADS VIEW
    // ========================================

    function renderDownloads() {
      const content = $('downloads-content');
      if (state.downloads.length === 0) {
        content.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-circle-down"></i></div>
            <div class="empty-title">No downloads yet</div>
            <div class="empty-sub">Downloaded episodes will appear here</div>
          </div>
        `;
        return;
      }
      
      content.innerHTML = state.downloads.map(dl => `
        <div class="dl-item">
          <button class="ep-play-btn" style="width:40px;height:40px" onclick="playDownloadedEpisode('${escAttr(dl.url)}')"><i class="fas fa-play"></i></button>
          <div class="dl-item-info">
            <div class="dl-item-title">${escAttr(dl.title)}</div>
            <div class="dl-item-sub">${escAttr(dl.podcastTitle)}</div>
            ${dl.date ? `<div class="dl-item-sub" style="color:var(--text-3);margin-top:2px;font-size:11px">${formatDate(dl.date)}</div>` : ''}
            ${dl.duration ? `<div class="dl-item-sub" style="color:var(--text-3);font-size:11px">${formatDuration(dl.duration)}</div>` : ''}
            ${dl.status === 'downloading' ? `
              <div class="dl-item-progress">
                <div class="dl-item-progress-fill" style="width:${dl.progress}%"></div>
              </div>
              <div class="dl-item-sub" style="color:var(--accent)">${dl.progress}% downloading</div>
            ` : dl.status === 'failed' ? `
              <div class="dl-item-sub" style="color:var(--error)">${escAttr(dl.error || 'Download failed')}</div>
            ` : ''}
          </div>
          <div class="dl-item-actions">
            ${dl.status === 'done' ? `<button class="dl-item-btn ${state.savingDownloads.has(dl.id) ? 'saving' : ''}" id="save-btn-${dl.id}" onclick="saveDownloadToDevice('${dl.id}')" ${state.savingDownloads.has(dl.id) ? 'disabled' : ''}><i class="fas ${state.savingDownloads.has(dl.id) ? 'fa-spinner fa-spin' : 'fa-download'}"></i>${state.savingDownloads.has(dl.id) ? 'Saving...' : ''}</button>` : ''}
            <button class="dl-item-btn delete" onclick="deleteDownload('${dl.id}')"><i class="fas fa-trash"></i></button>
          </div>
        </div>
      `).join('');
    }

    function playDownloadedEpisode(url) {
      const dl = state.downloads.find(d => d.url === url && d.status === 'done');
      if (dl && dl.blob) {
        const blobUrl = URL.createObjectURL(dl.blob);
        state.currentEpisode = { title: dl.title, url: blobUrl };
        state.currentPodcast = { title: dl.podcastTitle, image: dl.podcastImage };
        audio.src = blobUrl;
        audio.play().catch(e => showToast('Playback failed', 'error'));
        state.isPlaying = true;
        updatePlayerUI();
        $('mini-player').classList.add('visible');
        $('fp-bottom-actions').style.display = 'flex';
      }
    }

    function clearDownloads() {
      if (confirm('Delete all downloads?')) {
        state.downloads = [];
        saveState();
        renderDownloads();
        updateAllDownloadButtons();
        showToast('Downloads cleared', '');
      }
    }

    // ========== FOLLOWING FEED ========== 
    async function loadFollowingFeed() {
      const content = $('following-content');
      
      if (state.follows.length === 0) {
        content.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon"><i class="far fa-heart"></i></div>
            <div class="empty-title">No followed podcasts</div>
            <div class="empty-sub">When you follow podcasts, their latest episodes will appear here</div>
          </div>
        `;
        return;
      }
      
      content.innerHTML = '<div style="padding:40px;text-align:center"><i class="fas fa-spinner fa-spin" style="font-size:24px;color:var(--text-3)"></i></div>';
      
      try {
        const allEps = [];
        
        for (const follow of state.follows) {
          try {
            const res = await fetchWithProxy(follow.rss);
            const xml = await res.text();
            const parsed = parseRSS(xml);
            parsed.episodes.slice(0, MAX_FEED_EPISODES).forEach(ep => {
              allEps.push({ ...ep, podcastTitle: follow.title, podcastImage: follow.image });
            });
          } catch(e) {}
        }
        
        allEps.sort((a, b) => new Date(b.date) - new Date(a.date));
        
        if (allEps.length === 0) {
          content.innerHTML = `
            <div class="empty-state">
              <div class="empty-icon"><i class="fas fa-inbox"></i></div>
              <div class="empty-title">No episodes yet</div>
              <div class="empty-sub">Your followed podcasts haven't published new episodes</div>
            </div>
          `;
          return;
        }
        
        content.innerHTML = allEps.map(ep => `
          <div class="feed-ep" onclick="playEpisode(0)">
            <img src="${ep.podcastImage}" alt="" class="feed-ep-art" onerror="this.style.background='var(--surface-3)'">
            <div class="feed-ep-info">
              <div class="feed-ep-pod">${escAttr(ep.podcastTitle)}</div>
              <div class="feed-ep-title">${escAttr(ep.title)}</div>
              <div class="feed-ep-meta">
                <span>${formatDate(ep.date)}</span>
              </div>
            </div>
            <div style="position:relative">
              <button class="ep-dl-btn" data-dl-url="${escAttr(ep.url)}" onclick="event.stopPropagation(); startDownload('${escAttr(ep.url)}', '${escAttr(ep.title)}', '${escAttr(ep.podcastTitle)}', '${escAttr(ep.podcastImage)}', '${escAttr(ep.date)}', '${escAttr(ep.duration)}')">
                <i class="fas fa-download"></i>
              </button>
              ${isDownloaded(ep.url) ? '<span style="position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;background:var(--success);display:flex;align-items:center;justify-content:center;font-size:10px;color:#fff"><i class="fas fa-check"></i></span>' : ''}
            </div>
          </div>
        `).join('');
        
        updateAllDownloadButtons();
      } catch(e) {
        content.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-exclamation-triangle"></i></div>
            <div class="empty-title">Load failed</div>
          </div>
        `;
      }
    }

    // ========================================
    // SETTINGS
    // ========================================

    function clearSearchHistory() {
      if (confirm('Clear search history?')) {
        state.searchHistory = [];
        saveState();
        renderSearchEmpty();
        showToast('History cleared', '');
      }
    }

    function clearFollows() {
      if (confirm('Unfollow all podcasts?')) {
        state.follows = [];
        saveState();
        loadFollowingFeed();
        showToast('All unfollowed', '');
      }
    }

    // ========================================
    // AUDIO EVENTS
    // ========================================

    audio.addEventListener('play', () => {
      state.isPlaying = true;
      updatePlayIcon();
    });

    audio.addEventListener('pause', () => {
      state.isPlaying = false;
      updatePlayIcon();
    });

    audio.addEventListener('timeupdate', () => {
      if (isNaN(audio.duration)) return;
      const percent = audio.duration > 0 ? (audio.currentTime / audio.duration) * 100 : 0;
      $('mini-progress-fill').style.width = `${percent}%`;
      $('fp-seek-bar').value = percent * 10;
      $('fp-time-current').textContent = formatTime(audio.currentTime);
    });

    audio.addEventListener('loadedmetadata', () => {
      $('fp-seek-bar').max = 1000;
      $('fp-time-duration').textContent = formatTime(audio.duration);
    });

    audio.addEventListener('ended', () => {
      state.isPlaying = false;
      updatePlayIcon();
    });

    $('fp-seek-bar').addEventListener('input', (e) => {
      if (isNaN(audio.duration)) return;
      const percent = e.target.value / 1000;
      audio.currentTime = percent * audio.duration;
    });

    // ========================================
    // INIT
    // ========================================

    function init() {
      const speedHTML = SPEEDS.map(s => `
        <button class="speed-opt ${s === state.speed ? 'active' : ''}" onclick="state.speed=${s};audio.playbackRate=${s};saveState();this.parentElement.querySelectorAll('.speed-opt').forEach(b=>b.classList.remove('active'));this.classList.add('active')">${s}x</button>
      `).join('');
      $('speed-options').innerHTML = speedHTML;
      
      audio.playbackRate = state.speed;
      renderSearchEmpty();
    }

    init();
  </script>
</body>
</html>
